{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Overdefensive Silent Failure Summary",
  "type": "object",
  "required": [
    "schema_version",
    "skill",
    "generated_at",
    "repo_root",
    "overall_verdict",
    "summary_line",
    "severity_counts",
    "coverage",
    "findings",
    "dependency_status",
    "bootstrap_actions",
    "dependency_failures"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "skill": {
      "const": "overdefensive-silent-failure-hardgate"
    },
    "generated_at": {
      "type": "string"
    },
    "repo_root": {
      "type": "string"
    },
    "overall_verdict": {
      "type": "string",
      "enum": [
        "not-applicable",
        "scan-blocked",
        "silent-failure-risk",
        "contract-softened",
        "observable-degrade",
        "fail-loud"
      ]
    },
    "summary_line": {
      "type": "string"
    },
    "coverage": {
      "type": "object",
      "required": [
        "files_scanned",
        "python_files",
        "ts_files",
        "js_files"
      ],
      "properties": {
        "files_scanned": {
          "type": "integer"
        },
        "python_files": {
          "type": "integer"
        },
        "ts_files": {
          "type": "integer"
        },
        "js_files": {
          "type": "integer"
        }
      }
    },
    "severity_counts": {
      "type": "object",
      "required": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "critical": {
          "type": "integer"
        },
        "high": {
          "type": "integer"
        },
        "medium": {
          "type": "integer"
        },
        "low": {
          "type": "integer"
        }
      }
    },
    "category_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "scan_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "severity",
          "confidence",
          "language",
          "title",
          "path",
          "line",
          "evidence",
          "recommendation",
          "merge_gate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendation": {
            "type": "string"
          },
          "merge_gate": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "dependency_status": {
      "type": "string",
      "enum": [
        "ready",
        "auto-installed",
        "blocked"
      ]
    },
    "bootstrap_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bootstrapAction"
      }
    },
    "dependency_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyFailure"
      }
    }
  },
  "$defs": {
    "bootstrapAction": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "status",
        "command",
        "details"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      }
    },
    "dependencyFailure": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "required_for",
        "attempted_command",
        "failure_reason",
        "blocked_by_security",
        "blocked_by_permissions",
        "blocked_by_network"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required_for": {
          "type": "string"
        },
        "attempted_command": {
          "type": "string"
        },
        "failure_reason": {
          "type": "string"
        },
        "blocked_by_security": {
          "type": "boolean"
        },
        "blocked_by_permissions": {
          "type": "boolean"
        },
        "blocked_by_network": {
          "type": "boolean"
        }
      }
    }
  }
}
