{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ControlledCleanupSummary",
  "type": "object",
  "required": [
    "repo_root",
    "generated_at",
    "repo_profile",
    "counts",
    "findings",
    "dependency_status",
    "bootstrap_actions",
    "dependency_failures"
  ],
  "properties": {
    "repo_root": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "repo_profile": {
      "type": "object",
      "required": [
        "languages",
        "manifests",
        "tool_hints"
      ],
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manifests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "docs_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tool_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "required": [
        "total",
        "by_category"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "by_category": {
          "type": "object"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "category",
          "severity",
          "confidence",
          "path",
          "summary",
          "evidence"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "scan-blocker",
              "evidence-gap",
              "deprecated-surface",
              "compatibility-shim",
              "expired-removal-target",
              "marker-gap",
              "stale-doc-reference",
              "feature-flag-debt",
              "dynamic-entrypoint-risk",
              "cleanup-opportunity"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "path": {
            "type": "string"
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "language": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": "string"
          },
          "cue": {
            "type": [
              "string",
              "null"
            ]
          },
          "replacement": {
            "type": [
              "string",
              "null"
            ]
          },
          "removal_target": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependency_status": {
      "type": "string",
      "enum": [
        "ready",
        "auto-installed",
        "blocked"
      ]
    },
    "bootstrap_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bootstrapAction"
      }
    },
    "dependency_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyFailure"
      }
    }
  },
  "$defs": {
    "bootstrapAction": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "status",
        "command",
        "details"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      }
    },
    "dependencyFailure": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "required_for",
        "attempted_command",
        "failure_reason",
        "blocked_by_security",
        "blocked_by_permissions",
        "blocked_by_network"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required_for": {
          "type": "string"
        },
        "attempted_command": {
          "type": "string"
        },
        "failure_reason": {
          "type": "string"
        },
        "blocked_by_security": {
          "type": "boolean"
        },
        "blocked_by_permissions": {
          "type": "boolean"
        },
        "blocked_by_network": {
          "type": "boolean"
        }
      }
    }
  }
}
