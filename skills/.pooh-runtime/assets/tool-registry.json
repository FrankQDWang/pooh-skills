{
  "schema_version": "1.0",
  "base_prerequisites": {
    "python": [
      "python3",
      "uv"
    ],
    "node": [
      "node",
      "pnpm"
    ]
  },
  "runtime_features": {
    "mcp-context7": {
      "kind": "runtime-feature",
      "required_for": "verified-doc-verification",
      "detect": {
        "type": "env_or_http",
        "env": "POOH_RUNTIME_FEATURE_MCP_CONTEXT7",
        "url": "https://mcp.context7.com/mcp",
        "timeout_seconds": 5
      },
      "failure_reason": "Context7 MCP is unavailable or unreachable from this host."
    },
    "codex-subagents": {
      "kind": "runtime-feature",
      "required_for": "repo-health-orchestration",
      "detect": {
        "type": "env_flag",
        "env": "POOH_RUNTIME_FEATURE_CODEX_SUBAGENTS"
      },
      "failure_reason": "Codex subagent capability is unavailable in the current runtime."
    }
  },
  "tools": {
    "tach": {
      "ecosystem": "python",
      "version": "0.34.0",
      "binary_names": [
        "tach"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "0.34.0"
    },
    "ruff": {
      "ecosystem": "python",
      "version": "0.15.8",
      "binary_names": [
        "ruff"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "0.15.8"
    },
    "bandit": {
      "ecosystem": "python",
      "version": "1.8.6",
      "binary_names": [
        "bandit"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "1.8.6"
    },
    "check-jsonschema": {
      "ecosystem": "python",
      "version": "0.34.1",
      "binary_names": [
        "check-jsonschema"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "0.34.1"
    },
    "semgrep": {
      "ecosystem": "python",
      "version": "1.156.0",
      "binary_names": [
        "semgrep"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "1.156.0"
    },
    "typescript-eslint-stack": {
      "ecosystem": "node",
      "version": "eslint 9.39.4 / @typescript-eslint 8.57.2",
      "binary_names": [
        "eslint"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "9.39.4"
    },
    "biome": {
      "ecosystem": "node",
      "version": "2.2.7",
      "binary_names": [
        "biome"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "2.2.7"
    },
    "redocly-cli": {
      "ecosystem": "node",
      "version": "2.11.1",
      "binary_names": [
        "redocly"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "2.11.1"
    },
    "spectral-cli": {
      "ecosystem": "node",
      "version": "6.15.0",
      "binary_names": [
        "spectral"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "6.15.0"
    },
    "ajv-cli": {
      "ecosystem": "node",
      "version": "5.0.0",
      "binary_names": [
        "ajv"
      ],
      "check_args": [
        "help"
      ],
      "check_match": "Validate data file(s) against schema"
    },
    "playwright": {
      "ecosystem": "node",
      "version": "1.56.1",
      "binary_names": [
        "playwright"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "1.56.1"
    },
    "vitest": {
      "ecosystem": "node",
      "version": "4.0.7",
      "binary_names": [
        "vitest"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "4.0.7"
    },
    "tsc": {
      "ecosystem": "node",
      "version": "5.9.3",
      "binary_names": [
        "tsc"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "5.9.3"
    },
    "basedpyright": {
      "ecosystem": "node",
      "version": "1.38.4",
      "binary_names": [
        "basedpyright"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "1.38.4"
    },
    "dependency-cruiser": {
      "ecosystem": "node",
      "version": "17.3.10",
      "binary_names": [
        "depcruise"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "17.3.10"
    },
    "knip": {
      "ecosystem": "node",
      "version": "6.1.0",
      "binary_names": [
        "knip"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "6.1.0"
    },
    "ast-grep": {
      "ecosystem": "node",
      "version": "0.42.0",
      "binary_names": [
        "ast-grep"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "0.42.0"
    },
    "lychee": {
      "ecosystem": "docs",
      "version": "0.23.0",
      "binary_names": [
        "lychee"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "0.23.0",
      "download": {
        "owner": "lycheeverse",
        "repo": "lychee",
        "tag": "lychee-v0.23.0",
        "assets": {
          "darwin-arm64": "lychee-arm64-macos.tar.gz",
          "linux-x64": "lychee-x86_64-unknown-linux-gnu.tar.gz",
          "linux-arm64": "lychee-aarch64-unknown-linux-gnu.tar.gz"
        },
        "archive_type": "tar.gz",
        "binary_path": "lychee"
      }
    },
    "vale": {
      "ecosystem": "docs",
      "version": "3.14.1",
      "binary_names": [
        "vale"
      ],
      "check_args": [
        "--version"
      ],
      "check_match": "3.14.1",
      "download": {
        "owner": "errata-ai",
        "repo": "vale",
        "tag": "v3.14.1",
        "assets": {
          "darwin-arm64": "vale_3.14.1_macOS_arm64.tar.gz",
          "darwin-x64": "vale_3.14.1_macOS_64-bit.tar.gz",
          "linux-x64": "vale_3.14.1_Linux_64-bit.tar.gz",
          "linux-arm64": "vale_3.14.1_Linux_arm64.tar.gz"
        },
        "archive_type": "tar.gz",
        "binary_path": "vale"
      }
    }
  }
}
