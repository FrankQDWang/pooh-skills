{
  "schema_version": "1.0",
  "skill": "dependency-audit",
  "runtime_features": [],
  "dependencies": [
    {
      "name": "tach",
      "kind": "cli",
      "required_for": "python-boundary-audit",
      "required_when": {
        "languages_any": [
          "python"
        ]
      },
      "detect": {
        "type": "any_command",
        "commands": [
          "tach"
        ]
      },
      "install_attempts": [
        {
          "command": [
            "python3",
            "-m",
            "pip",
            "install",
            "--user",
            "--upgrade",
            "tach"
          ]
        },
        {
          "command": [
            "python3",
            "-m",
            "pip",
            "install",
            "--user",
            "--break-system-packages",
            "--upgrade",
            "tach"
          ]
        },
        {
          "command": [
            "pipx",
            "install",
            "tach"
          ]
        }
      ]
    },
    {
      "name": "node-toolchain",
      "kind": "toolchain",
      "required_for": "javascript-typescript-audit",
      "required_when": {
        "languages_any": [
          "javascript",
          "typescript"
        ]
      },
      "detect": {
        "type": "any_command",
        "commands": [
          "npm"
        ]
      },
      "install_attempts": [
        {
          "platforms": [
            "darwin",
            "macos"
          ],
          "command": [
            "brew",
            "install",
            "node"
          ]
        }
      ]
    },
    {
      "name": "dependency-cruiser",
      "kind": "cli",
      "required_for": "javascript-typescript-audit",
      "required_when": {
        "languages_any": [
          "javascript",
          "typescript"
        ]
      },
      "detect": {
        "type": "any_command",
        "commands": [
          "depcruise",
          "dependency-cruiser"
        ]
      },
      "install_attempts": [
        {
          "command": [
            "npm",
            "install",
            "-g",
            "dependency-cruiser"
          ]
        }
      ]
    },
    {
      "name": "knip",
      "kind": "cli",
      "required_for": "javascript-typescript-deadcode-audit",
      "required_when": {
        "languages_any": [
          "javascript",
          "typescript"
        ]
      },
      "detect": {
        "type": "any_command",
        "commands": [
          "knip"
        ]
      },
      "install_attempts": [
        {
          "command": [
            "npm",
            "install",
            "-g",
            "knip"
          ]
        }
      ]
    }
  ]
}
