{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/llm-api-freshness-summary.schema.json",
  "title": "LLM API Freshness Guard Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "version",
    "generated_at",
    "mode",
    "repo_profile",
    "doc_verification",
    "findings",
    "priorities",
    "scan_limitations",
    "dependency_status",
    "bootstrap_actions",
    "dependency_failures"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "verified"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "doc_verification": {
            "type": "array",
            "minItems": 1,
            "contains": {
              "type": "object",
              "properties": {
                "status": {
                  "const": "verified"
                }
              },
              "required": [
                "status"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "blocked"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "dependency_status": {
            "const": "blocked"
          }
        }
      }
    }
  ],
  "properties": {
    "skill": {
      "const": "llm-api-freshness-guard"
    },
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "verified",
        "local-scan-only",
        "blocked"
      ]
    },
    "repo_profile": {
      "$ref": "#/$defs/repoProfile"
    },
    "doc_verification": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/docVerification"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "priorities": {
      "$ref": "#/$defs/priorities"
    },
    "scan_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependency_status": {
      "enum": [
        "ready",
        "auto-installed",
        "blocked"
      ]
    },
    "bootstrap_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bootstrapAction"
      }
    },
    "dependency_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyFailure"
      }
    }
  },
  "$defs": {
    "repoProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_root",
        "files_scanned",
        "languages",
        "providers_detected",
        "provider_scores",
        "wrappers_detected",
        "version_hints",
        "model_hints",
        "base_url_hints"
      ],
      "properties": {
        "repo_root": {
          "type": "string"
        },
        "files_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "providers_detected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_scores": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "wrappers_detected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "version_hints": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "model_hints": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "base_url_hints": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "docVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "library",
        "library_id",
        "language",
        "version_hint",
        "queries",
        "status",
        "notes"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "library": {
          "type": "string"
        },
        "library_id": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "version_hint": {
          "type": "string"
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "enum": [
            "verified",
            "ambiguous",
            "failed",
            "skipped"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "provider",
        "kind",
        "severity",
        "confidence",
        "status",
        "scope",
        "title",
        "stale_usage",
        "current_expectation",
        "evidence",
        "recommended_change_shape",
        "docs_verified",
        "autofix_allowed",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "scan-blocker",
            "provider-ambiguous",
            "docs-unverified",
            "local-suspicion",
            "sdk-stale",
            "endpoint-stale",
            "request-schema-drift",
            "response-shape-drift",
            "tool-calling-drift",
            "streaming-drift",
            "structured-output-drift",
            "model-stale",
            "auth-config-drift",
            "compat-layer-drift",
            "wrapper-pass-through-risk"
          ]
        },
        "severity": {
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "status": {
          "enum": [
            "present",
            "possible",
            "unknown"
          ]
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "title": {
          "type": "string"
        },
        "stale_usage": {
          "type": "string"
        },
        "current_expectation": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "recommended_change_shape": {
          "type": "string"
        },
        "docs_verified": {
          "type": "boolean"
        },
        "autofix_allowed": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line",
        "snippet"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "snippet": {
          "type": "string"
        }
      }
    },
    "priorities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "now",
        "next",
        "later"
      ],
      "properties": {
        "now": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "later": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "bootstrapAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "status",
        "command",
        "details"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      }
    },
    "dependencyFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "required_for",
        "attempted_command",
        "failure_reason",
        "blocked_by_security",
        "blocked_by_permissions",
        "blocked_by_network"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required_for": {
          "type": "string"
        },
        "attempted_command": {
          "type": "string"
        },
        "failure_reason": {
          "type": "string"
        },
        "blocked_by_security": {
          "type": "boolean"
        },
        "blocked_by_permissions": {
          "type": "boolean"
        },
        "blocked_by_network": {
          "type": "boolean"
        }
      }
    }
  }
}
