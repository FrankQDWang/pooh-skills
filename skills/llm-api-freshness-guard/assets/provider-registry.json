{
  "version": "1.0.0",
  "providers": [
    "openai",
    "anthropic",
    "gemini",
    "azure-openai",
    "openrouter",
    "bedrock"
  ],
  "wrappers": [
    "litellm",
    "langchain",
    "vercel-ai-sdk",
    "pydantic-ai",
    "instructor"
  ],
  "package_hints": {
    "openai": { "provider": "openai", "wrapper": null },
    "@anthropic-ai/sdk": { "provider": "anthropic", "wrapper": null },
    "anthropic": { "provider": "anthropic", "wrapper": null },
    "@google/genai": { "provider": "gemini", "wrapper": null },
    "@google/generative-ai": { "provider": "gemini", "wrapper": null },
    "google-generativeai": { "provider": "gemini", "wrapper": null },
    "google-genai": { "provider": "gemini", "wrapper": null },
    "litellm": { "provider": null, "wrapper": "litellm" },
    "langchain": { "provider": null, "wrapper": "langchain" },
    "@langchain/openai": { "provider": "openai", "wrapper": "langchain" },
    "@langchain/anthropic": { "provider": "anthropic", "wrapper": "langchain" },
    "@langchain/google-genai": { "provider": "gemini", "wrapper": "langchain" },
    "langchain-openai": { "provider": "openai", "wrapper": "langchain" },
    "langchain-anthropic": { "provider": "anthropic", "wrapper": "langchain" },
    "langchain-google-genai": { "provider": "gemini", "wrapper": "langchain" },
    "ai": { "provider": null, "wrapper": "vercel-ai-sdk" },
    "@ai-sdk/openai": { "provider": "openai", "wrapper": "vercel-ai-sdk" },
    "@ai-sdk/anthropic": { "provider": "anthropic", "wrapper": "vercel-ai-sdk" },
    "@ai-sdk/google": { "provider": "gemini", "wrapper": "vercel-ai-sdk" },
    "pydantic-ai": { "provider": null, "wrapper": "pydantic-ai" },
    "instructor": { "provider": null, "wrapper": "instructor" }
  },
  "signal_patterns": [
    {
      "label": "openai-import",
      "category": "direct-sdk",
      "weight": 5,
      "provider": "openai",
      "regex": "\\bfrom\\s+openai\\s+import\\b|\\bimport\\s+openai\\b|\\brequire\\(['\\\"]openai['\\\"]\\)|\\bfrom\\s+['\\\"]openai['\\\"]|\\bnew\\s+OpenAI\\s*\\("
    },
    {
      "label": "openai-env",
      "category": "env",
      "weight": 3,
      "provider": "openai",
      "regex": "\\bOPENAI_API_KEY\\b"
    },
    {
      "label": "openai-url",
      "category": "base-url",
      "weight": 4,
      "provider": "openai",
      "regex": "api\\.openai\\.com"
    },
    {
      "label": "openai-chat-completions-suspect",
      "category": "legacy-surface-suspect",
      "weight": 2,
      "provider": "openai",
      "regex": "\\bchat\\.completions\\.create\\s*\\("
    },
    {
      "label": "openai-chatcompletion-legacy",
      "category": "stale-pattern",
      "weight": 3,
      "provider": "openai",
      "regex": "\\bopenai\\.ChatCompletion\\.create\\s*\\("
    },
    {
      "label": "openai-completion-legacy",
      "category": "stale-pattern",
      "weight": 3,
      "provider": "openai",
      "regex": "\\bopenai\\.Completion\\.create\\s*\\("
    },
    {
      "label": "openai-functions-arg",
      "category": "stale-pattern",
      "weight": 2,
      "provider": "openai",
      "regex": "\\bfunctions\\s*="
    },
    {
      "label": "openai-function-call-arg",
      "category": "stale-pattern",
      "weight": 2,
      "provider": "openai",
      "regex": "\\bfunction_call\\s*="
    },
    {
      "label": "anthropic-import",
      "category": "direct-sdk",
      "weight": 5,
      "provider": "anthropic",
      "regex": "\\bfrom\\s+anthropic\\s+import\\b|\\bimport\\s+anthropic\\b|\\brequire\\(['\\\"]@anthropic-ai/sdk['\\\"]\\)|\\bfrom\\s+['\\\"]@anthropic-ai/sdk['\\\"]|\\bnew\\s+Anthropic\\s*\\("
    },
    {
      "label": "anthropic-env",
      "category": "env",
      "weight": 3,
      "provider": "anthropic",
      "regex": "\\bANTHROPIC_API_KEY\\b"
    },
    {
      "label": "anthropic-url",
      "category": "base-url",
      "weight": 4,
      "provider": "anthropic",
      "regex": "api\\.anthropic\\.com"
    },
    {
      "label": "anthropic-messages",
      "category": "surface",
      "weight": 2,
      "provider": "anthropic",
      "regex": "\\b(?:anthropic|client)\\.messages\\.create\\s*\\("
    },
    {
      "label": "anthropic-complete-endpoint",
      "category": "stale-pattern",
      "weight": 3,
      "provider": "anthropic",
      "regex": "/v1/complete\\b"
    },
    {
      "label": "anthropic-completions-create",
      "category": "stale-pattern",
      "weight": 3,
      "provider": "anthropic",
      "regex": "\\b(?:anthropic|client)\\.completions\\.create\\s*\\("
    },
    {
      "label": "anthropic-max-tokens-to-sample",
      "category": "stale-pattern",
      "weight": 2,
      "provider": "anthropic",
      "regex": "\\bmax_tokens_to_sample\\b"
    },
    {
      "label": "anthropic-human-ai-prompts",
      "category": "stale-pattern",
      "weight": 2,
      "provider": "anthropic",
      "regex": "\\bHUMAN_PROMPT\\b|\\bAI_PROMPT\\b"
    },
    {
      "label": "gemini-import",
      "category": "direct-sdk",
      "weight": 5,
      "provider": "gemini",
      "regex": "\\bimport\\s+google\\.generativeai\\b|\\bfrom\\s+google\\s+import\\s+generativeai\\b|\\bfrom\\s+google\\.genai\\s+import\\b|\\bimport\\s+google\\.genai\\b|\\brequire\\(['\\\"]@google/genai['\\\"]\\)|\\bfrom\\s+['\\\"]@google/genai['\\\"]|\\brequire\\(['\\\"]@google/generative-ai['\\\"]\\)|\\bfrom\\s+['\\\"]@google/generative-ai['\\\"]"
    },
    {
      "label": "gemini-env",
      "category": "env",
      "weight": 3,
      "provider": "gemini",
      "regex": "\\bGOOGLE_API_KEY\\b|\\bGEMINI_API_KEY\\b"
    },
    {
      "label": "gemini-url",
      "category": "base-url",
      "weight": 4,
      "provider": "gemini",
      "regex": "generativelanguage\\.googleapis\\.com"
    },
    {
      "label": "gemini-generate-content",
      "category": "surface",
      "weight": 2,
      "provider": "gemini",
      "regex": "\\bgenerate_?content\\s*\\("
    },
    {
      "label": "gemini-legacy-python-sdk",
      "category": "legacy-surface-suspect",
      "weight": 2,
      "provider": "gemini",
      "regex": "\\bgoogle\\.generativeai\\b"
    },
    {
      "label": "azure-openai-env",
      "category": "env",
      "weight": 4,
      "provider": "azure-openai",
      "regex": "\\bAZURE_OPENAI_API_KEY\\b|\\bAZURE_OPENAI_ENDPOINT\\b|\\bAZURE_OPENAI\\b"
    },
    {
      "label": "azure-openai-url",
      "category": "base-url",
      "weight": 5,
      "provider": "azure-openai",
      "regex": "\\bopenai\\.azure\\.com\\b"
    },
    {
      "label": "azure-openai-client",
      "category": "direct-sdk",
      "weight": 5,
      "provider": "azure-openai",
      "regex": "\\bAzureOpenAI\\b"
    },
    {
      "label": "azure-openai-api-version",
      "category": "compatibility-layer",
      "weight": 2,
      "provider": "azure-openai",
      "regex": "\\bapi-version\\b|\\bapi_version\\b"
    },
    {
      "label": "openrouter-url",
      "category": "base-url",
      "weight": 5,
      "provider": "openrouter",
      "regex": "\\bopenrouter\\.ai\\b"
    },
    {
      "label": "openrouter-env",
      "category": "env",
      "weight": 3,
      "provider": "openrouter",
      "regex": "\\bOPENROUTER_API_KEY\\b"
    },
    {
      "label": "bedrock-runtime",
      "category": "compatibility-layer",
      "weight": 5,
      "provider": "bedrock",
      "regex": "\\bbedrock-runtime\\b|\\bbedrockruntime\\b|\\bboto3\\.client\\(['\\\"]bedrock-runtime['\\\"]\\)"
    },
    {
      "label": "litellm-import",
      "category": "wrapper",
      "weight": 4,
      "wrapper": "litellm",
      "regex": "\\bimport\\s+litellm\\b|\\bfrom\\s+litellm\\s+import\\b|\\blitellm\\b"
    },
    {
      "label": "langchain-import",
      "category": "wrapper",
      "weight": 4,
      "wrapper": "langchain",
      "regex": "\\blangchain[_\\-]openai\\b|\\blangchain[_\\-]anthropic\\b|\\blangchain[_\\-]google[_\\-]genai\\b|\\bfrom\\s+langchain\\b|\\bChatOpenAI\\b|\\bChatAnthropic\\b|\\bChatGoogleGenerativeAI\\b"
    },
    {
      "label": "vercel-ai-sdk-import",
      "category": "wrapper",
      "weight": 4,
      "wrapper": "vercel-ai-sdk",
      "regex": "\\bfrom\\s+['\\\"]ai['\\\"]|\\brequire\\(['\\\"]ai['\\\"]\\)|\\b@ai-sdk/"
    },
    {
      "label": "pydantic-ai-import",
      "category": "wrapper",
      "weight": 4,
      "wrapper": "pydantic-ai",
      "regex": "\\bpydantic_ai\\b|\\bpydantic-ai\\b"
    },
    {
      "label": "instructor-import",
      "category": "wrapper",
      "weight": 4,
      "wrapper": "instructor",
      "regex": "\\binstructor\\b"
    }
  ],
  "model_patterns": {
    "openai": "\\bgpt-[A-Za-z0-9._:-]+\\b",
    "anthropic": "\\bclaude-[A-Za-z0-9._:-]+\\b",
    "gemini": "\\bgemini-[A-Za-z0-9._:-]+\\b",
    "bedrock": "\\banthropic\\.[A-Za-z0-9._:-]+\\b"
  },
  "url_patterns": {
    "openai": "https?://[^\\s'\\\"`]+api\\.openai\\.com[^\\s'\\\"`]*",
    "anthropic": "https?://[^\\s'\\\"`]+api\\.anthropic\\.com[^\\s'\\\"`]*",
    "gemini": "https?://[^\\s'\\\"`]+generativelanguage\\.googleapis\\.com[^\\s'\\\"`]*",
    "azure-openai": "https?://[^\\s'\\\"`]+openai\\.azure\\.com[^\\s'\\\"`]*",
    "openrouter": "https?://[^\\s'\\\"`]+openrouter\\.ai[^\\s'\\\"`]*"
  }
}
