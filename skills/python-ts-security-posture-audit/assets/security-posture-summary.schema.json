{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Python TypeScript Security Posture Audit Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill",
    "status",
    "verdict",
    "repo_scope",
    "package_managers",
    "categories",
    "findings",
    "run_id",
    "generated_at",
    "repo_root",
    "overall_verdict",
    "rollup_bucket",
    "dependency_status",
    "dependency_failures",
    "bootstrap_actions",
    "severity_counts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "skill": {
      "type": "string",
      "const": "python-ts-security-posture-audit"
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "blocked",
        "not-applicable"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "missing",
        "theater",
        "partial",
        "enforced",
        "hardened",
        "unverified",
        "blocked",
        "not-applicable"
      ]
    },
    "repo_scope": {
      "type": "string"
    },
    "package_managers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "uv",
          "pnpm"
        ]
      }
    },
    "summary": {
      "type": "string"
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "state",
          "confidence",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "python-known-vulns",
              "ts-known-vulns",
              "python-static-security",
              "lockfile-install-discipline",
              "gate-and-ignore-governance"
            ]
          },
          "title": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "missing",
              "theater",
              "partial",
              "enforced",
              "hardened",
              "unverified",
              "blocked",
              "not-applicable"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "severity",
          "confidence",
          "title",
          "evidence",
          "recommended_change_shape"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "python-known-vulns",
              "ts-known-vulns",
              "python-static-security",
              "lockfile-install-discipline",
              "gate-and-ignore-governance"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_change_shape": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "run_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "repo_root": {
      "type": "string"
    },
    "overall_verdict": {
      "type": "string",
      "enum": [
        "scan-blocked",
        "partial",
        "enforced",
        "hardened",
        "not-applicable"
      ]
    },
    "rollup_bucket": {
      "type": "string",
      "enum": [
        "blocked",
        "red",
        "yellow",
        "green",
        "not-applicable"
      ]
    },
    "dependency_status": {
      "type": "string",
      "enum": [
        "ready",
        "auto-installed",
        "blocked"
      ]
    },
    "dependency_failures": {
      "type": "array"
    },
    "bootstrap_actions": {
      "type": "array"
    },
    "severity_counts": {
      "type": "object",
      "required": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
